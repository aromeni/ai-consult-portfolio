# Build 11 — Production AI Document Intelligence & Governance Agent
# Environment configuration example.
# Copy this file to .env and fill in values if required.
# The app runs fully locally without any API keys by default.

# Optional: OpenAI API key for LLM-assisted answer generation (not required).
# If omitted, the app uses grounded extractive answers from retrieved chunks.
# OPENAI_API_KEY=sk-...

# Optional: sentence-transformers model override.
# Defaults to all-MiniLM-L6-v2 if not set.
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: FAISS index type override (flat_ip or flat_l2).
# Defaults to flat_ip (cosine similarity via inner product on unit vectors).
# FAISS_INDEX_TYPE=flat_ip
